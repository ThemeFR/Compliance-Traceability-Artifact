cmmc:RegObligation_32CFR170 a owl:NamedIndividual, cmmc:RegulatoryObligation ;
    rdfs:label "32 CFR Part 170 — CMMC Program"@en ; cmmc:clauseIdentifier "32 CFR Part 170" .
cmmc:RegObligation_48CFR204 a owl:NamedIndividual, cmmc:RegulatoryObligation ;
    rdfs:label "48 CFR Part 204 — CMMC Acquisition"@en ; cmmc:clauseIdentifier "48 CFR Part 204" .
cmmc:FARClause_52_204_21 a owl:NamedIndividual, cmmc:RegulatoryObligation ;
    rdfs:label "FAR 52.204-21 — Basic Safeguarding of FCI"@en ; cmmc:clauseIdentifier "FAR 52.204-21" .

