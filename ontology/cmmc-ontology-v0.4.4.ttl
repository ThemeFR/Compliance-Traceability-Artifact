### 6.X — Assessment Tier Enum [EXTENDED v0.3.0]
cmmc:NIST800171AssessmentTier a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:oneOf (
            cmmc:BasicAssessment cmmc:MediumAssessment cmmc:HighAssessment
            cmmc:CMMC_L1 cmmc:CMMC_L2_Self cmmc:CMMC_L2_C3PAO cmmc:CMMC_L3
        )
    ] ;
    rdfs:label "Assessment Tier"@en .

