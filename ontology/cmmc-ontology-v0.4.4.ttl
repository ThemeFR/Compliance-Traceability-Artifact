cmmc:ResultSubmissionSystem a owl:Class ;
    owl:equivalentClass [ a owl:Class ; owl:oneOf ( cmmc:SPRS_System cmmc:eMASS_System ) ] ;
    rdfs:label "Result Submission System"@en .

cmmc:SPRS_System a owl:NamedIndividual, cmmc:ResultSubmissionSystem ; rdfs:label "SPRS"@en .
cmmc:eMASS_System a owl:NamedIndividual, cmmc:ResultSubmissionSystem ; rdfs:label "CMMC eMASS"@en .

### 6.Z2 — Limited Dissemination Control (LDC) Enum [NEW v0.4.0]
cmmc:LimitedDisseminationControl a owl:Class ;
    owl:equivalentClass [
        a owl:Class ;
        owl:oneOf ( cmmc:LDC_NOFORN cmmc:LDC_FED_ONLY cmmc:LDC_NOCON cmmc:LDC_REL_TO cmmc:LDC_DISPLAY_ONLY )
    ] ;
    rdfs:label "CUI Limited Dissemination Control"@en ;
    skos:exactMatch canon:LimitedDisseminationControl .

cmmc:LDC_NOFORN a owl:NamedIndividual, cmmc:LimitedDisseminationControl ; rdfs:label "NOFORN"@en .
cmmc:LDC_FED_ONLY a owl:NamedIndividual, cmmc:LimitedDisseminationControl ; rdfs:label "FED ONLY"@en .
cmmc:LDC_NOCON a owl:NamedIndividual, cmmc:LimitedDisseminationControl ; rdfs:label "NOCON"@en .
cmmc:LDC_REL_TO a owl:NamedIndividual, cmmc:LimitedDisseminationControl ; rdfs:label "REL TO"@en .
cmmc:LDC_DISPLAY_ONLY a owl:NamedIndividual, cmmc:LimitedDisseminationControl ; rdfs:label "DISPLAY ONLY"@en .

cmmc:CertificateAuthority_MedAssurance a owl:Class ; rdfs:label "Medium Assurance Certificate Authority"@en .


